<?xml version="1.0"?>
<ruleset name="Portal Akademik MKWK">
    <description>PHP CodeSniffer ruleset for Portal Akademik MKWK</description>

    <!-- Include PSR12 standard -->
    <rule ref="PSR12"/>

    <!-- Exclude directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/uploads/*</exclude-pattern>

    <!-- File extensions to check -->
    <arg name="extensions" value="php"/>

    <!-- Report settings -->
    <arg name="colors"/>
    <arg name="report" value="full"/>
</ruleset>
